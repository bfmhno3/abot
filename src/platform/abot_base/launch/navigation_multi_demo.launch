<launch>
    <node pkg="abot_base" type="mission.py" respawn="false" name="mission" output="screen">
        <param name="goalListX" value="1.0, 2.15, 2.15, 2.15, 1.0, 1.0, 0.1" />
        <param name="goalListY" value="-0.3, -0.3, -1.5, -2.65, -2.65, -1.5,-2.75" />
        <param name="goalListYaw" value="0, 0, 180, 180, 180, 0, 0" /><!--degree--> 
    </node>
</launch>
